<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="Glacithorn" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/Glacithorn" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
				</Compiler>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/Glacithorn" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add option="-fexceptions" />
			<Add directory="./Include" />
		</Compiler>
		<Linker>
			<Add library="ncurses" />
		</Linker>
		<Unit filename="Random.cpp" />
		<Unit filename="Random.h" />
		<Unit filename="Scanes/Hlavni.cpp" />
		<Unit filename="Scanes/Hlavni.h" />
		<Unit filename="Scanes/Scanes.h" />
		<Unit filename="main.cpp" />
		<Unit filename="screen.cpp" />
		<Unit filename="screen.h" />
		<Unit filename="sprites.cpp" />
		<Unit filename="sprites.h" />
		<Extensions />
	</Project>
</CodeBlocks_project_file>
